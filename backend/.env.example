# Copy to .env and fill in your values — NEVER commit .env to git

# Must be "development" locally — enables /docs, and (as of the config
# fail-fast check) is what allows SUPABASE_URL/SUPABASE_SERVICE_KEY/SECRET_KEY
# to keep their harmless local defaults below. Defaults to "production" if
# unset, and a REAL production deploy will refuse to boot if any of those
# three still hold their dev/placeholder value — see app/core/config.py.
ENVIRONMENT=development

ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional: Supabase (auth + chat history). Leave as dummy to skip DB features.
SUPABASE_URL=http://localhost
SUPABASE_ANON_KEY=dummy
SUPABASE_SERVICE_KEY=dummy

# Optional: direct Postgres connection string (Supabase dashboard → Settings
# → Database), only used by scripts/backup_db.sh for nightly pg_dump backups
# — never used by the running app itself. See docs/DISASTER_RECOVERY.md.
DATABASE_URL=

# Change this to a random 32-char string in production
SECRET_KEY=change-this-to-a-random-32-char-string

# Set to * for beta, or your actual frontend URL later
FRONTEND_URL=*

# Twilio SMS — necesario para recuperar contraseña por SMS
# Obtén estos valores en: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+12025551234
