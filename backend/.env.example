# Copy to .env and fill in your values — NEVER commit .env to git

ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional: Supabase (auth + chat history). Leave as dummy to skip DB features.
SUPABASE_URL=http://localhost
SUPABASE_ANON_KEY=dummy
SUPABASE_SERVICE_KEY=dummy

# Change this to a random 32-char string in production
SECRET_KEY=change-this-to-a-random-32-char-string

# Set to * for beta, or your actual frontend URL later
FRONTEND_URL=*
